# Copy file này thành .env và điền giá trị thực

# JWT secret key — dùng lệnh này để sinh: openssl rand -hex 32
SECRET_KEY=your-secret-key-here

# PIN 8 số để đăng nhập
APP_PIN=12345678

# PostgreSQL URL từ Neon (hoặc giữ SQLite khi dev local)
# Local SQLite:
DATABASE_URL=sqlite+aiosqlite:///./wealth.db
# Neon PostgreSQL (thay bằng URL thực từ Neon dashboard):
# DATABASE_URL=postgresql+asyncpg://user:pass@ep-xxx.us-east-2.aws.neon.tech/dbname?ssl=require

# Danh sách domain frontend được phép gọi API (cách nhau bằng dấu phẩy)
# Local dev:
ALLOWED_ORIGINS=http://localhost:8080,http://localhost:5173
# Production (thêm URL Vercel sau khi deploy):
# ALLOWED_ORIGINS=http://localhost:8080,http://localhost:5173,https://macufam.vercel.app
